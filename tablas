<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Spooler Simulación</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="p-4">
<div class="container">

<h4>Spooler - Simulación Completa</h4>

<!-- TABS -->
<ul class="nav nav-tabs mb-3">
  <li class="nav-item"><button class="nav-link active" onclick="setPresentacion(1)">Presentación 1</button></li>
  <li class="nav-item"><button class="nav-link" onclick="setPresentacion(2)">Presentación 2</button></li>
  <li class="nav-item"><button class="nav-link" onclick="setPresentacion(3)">Presentación 3</button></li>
</ul>

<div class="row">

<!-- IZQUIERDA -->
<div class="col-4">

<select class="form-control mb-2" onchange="setClave(this.value)">
  <option value="A">Clave A</option>
  <option value="B">Clave B</option>
  <option value="C">Clave C</option>
</select>

<button class="btn btn-primary btn-sm mb-2" onclick="addRollo()">Agregar Rollo</button>

<table class="table table-bordered">
<thead class="table-dark">
<tr>
  <th># Rollo</th>
  <th>KG</th>
  <th>ML</th>
</tr>
</thead>
<tbody id="tblRollos"></tbody>
</table>

</div>

<!-- DERECHA -->
<div class="col-8">

<div class="card mb-2">
<div class="card-body">

<div class="row">
  <div class="col-2">
    <input id="bajada" class="form-control form-control-sm" placeholder="# Bajada">
  </div>
  <div class="col-2">
    <input id="bobinas" type="number" class="form-control form-control-sm" placeholder="Bobinas">
  </div>
  <div class="col-2">
    <input id="kg" class="form-control form-control-sm" disabled placeholder="KG">
  </div>
  <div class="col-2">
    <input id="ml" class="form-control form-control-sm" disabled placeholder="ML">
  </div>
  <div class="col-2">
    <button class="btn btn-success btn-sm" onclick="guardar()">Guardar</button>
  </div>
</div>

</div>
</div>

<table class="table table-bordered">
<thead class="table-dark">
<tr>
  <th>Bajada</th>
  <th>Bobinas</th>
  <th>KG</th>
  <th>ML</th>
</tr>
</thead>
<tbody id="tblHistorial"></tbody>
</table>

</div>
</div>
</div>

<script>

// ===== ESTADO =====
const spoolers = {
  1: crear(),
  2: crear(),
  3: crear()
};

let current = 1;

function crear() {
  return {
    clave: 'A',
    rollos: [],
    historial: []
  };
}

// ===== CAMBIOS =====
function setPresentacion(n) {
  current = n;

  document.querySelectorAll('.nav-link').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.nav-link')[n-1].classList.add('active');

  render();
}

function setClave(c) {
  spoolers[current].clave = c;
}

// ===== ROLLOS =====
function addRollo() {
  spoolers[current].rollos.push({ rollo:'', kg:0, ml:0 });
  renderRollos();
}

function updateRollo(i, field, val) {
  spoolers[current].rollos[i][field] = Number(val);
  renderRollos();
}

// ===== GUARDAR =====
function guardar() {
  const p = spoolers[current];

  let totalKg = 0;
  let totalMl = 0;

  p.rollos.forEach(r => {
    totalKg += Number(r.kg || 0);
    totalMl += Number(r.ml || 0);
  });

  const row = {
    bajada: document.getElementById("bajada").value,
    bobinas: document.getElementById("bobinas").value,
    kg: totalKg,
    ml: totalMl
  };

  p.historial.push(row);

  // reset
  p.rollos = [];
  document.getElementById("bajada").value = "";
  document.getElementById("bobinas").value = "";
  document.getElementById("kg").value = "";
  document.getElementById("ml").value = "";

  render();
}

// ===== RENDER =====
function render() {
  renderRollos();
  renderHistorial();
}

function renderRollos() {
  const tbody = document.getElementById("tblRollos");
  tbody.innerHTML = "";

  let totalKg = 0;
  let totalMl = 0;

  spoolers[current].rollos.forEach((r,i) => {
    totalKg += Number(r.kg || 0);
    totalMl += Number(r.ml || 0);

    tbody.innerHTML += `
      <tr>
        <td><input class="form-control" value="${r.rollo || ''}" onchange="updateRollo(${i},'rollo',this.value)"></td>
        <td><input type="number" class="form-control" value="${r.kg || ''}" onchange="updateRollo(${i},'kg',this.value)"></td>
        <td><input type="number" class="form-control" value="${r.ml || ''}" onchange="updateRollo(${i},'ml',this.value)"></td>
      </tr>
    `;
  });

  // 🔥 FILA TOTAL
  tbody.innerHTML += `
    <tr class="table-secondary fw-bold">
      <td>TOTAL</td>
      <td>${totalKg}</td>
      <td>${totalMl}</td>
    </tr>
  `;

  // actualizar inputs
  document.getElementById("kg").value = totalKg;
  document.getElementById("ml").value = totalMl;
}

function renderHistorial() {
  const tbody = document.getElementById("tblHistorial");
  tbody.innerHTML = "";

  spoolers[current].historial.forEach(r => {
    tbody.innerHTML += `
      <tr>
        <td>${r.bajada}</td>
        <td>${r.bobinas}</td>
        <td>${r.kg}</td>
        <td>${r.ml}</td>
      </tr>
    `;
  });
}

// init
render();

</script>

</body>
</html>
