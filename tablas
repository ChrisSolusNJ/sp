<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Presentaciones SQL</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="p-4">

<div class="container">

<h3 class="mb-3">Presentaciones</h3>

<ul class="nav nav-tabs mb-3">
  <li class="nav-item"><button class="nav-link active" onclick="cambiarPresentacion(1)">Presentación 1</button></li>
  <li class="nav-item"><button class="nav-link" onclick="cambiarPresentacion(2)">Presentación 2</button></li>
  <li class="nav-item"><button class="nav-link" onclick="cambiarPresentacion(3)">Presentación 3</button></li>
</ul>

<div class="mb-3">
  <label class="form-label">Seleccionar Clave</label>
  <select class="form-select" id="selectorClave" onchange="cambiarClave(this.value)">
    <option value="A">Clave A</option>
    <option value="B">Clave B</option>
    <option value="C">Clave C</option>
  </select>
</div>

<div class="mb-3">
  <button class="btn btn-primary" onclick="agregarFila()">Agregar fila</button>
</div>

<table class="table table-bordered" id="tabla1">
  <thead class="table-dark">
    <tr>
      <th>ID</th>
      <th># Rollo</th>
      <th>Valor 1</th>
      <th>Valor 2</th>
    </tr>
  </thead>
  <tbody></tbody>
</table>

<button class="btn btn-success mb-3" onclick="procesar()">Procesar</button>

<h5>Tabla 2</h5>
<table class="table table-bordered" id="tabla2">
<thead class="table-dark">
<tr><th>ID</th><th>IDT1</th><th>V1</th><th>V2</th><th>V3</th></tr>
</thead>
<tbody></tbody>
</table>

<h5>Tabla 3</h5>
<table class="table table-bordered" id="tabla3">
<thead class="table-dark">
<tr><th>ID</th><th>IDT1</th><th>V1</th><th>V2</th><th>V3</th></tr>
</thead>
<tbody></tbody>
</table>

</div>

<script>
// estado por presentación
const presentaciones = {
  1: crearEstado(),
  2: crearEstado(),
  3: crearEstado()
};

let presentacionActiva = 1;

function crearEstado(){
  return {
    clave:'A',
    tabla1:[{id:1,val1:0,val2:0}],
  };
}

function getP(){ return presentaciones[presentacionActiva]; }

function cambiarPresentacion(num){
  presentacionActiva = num;

  document.querySelectorAll('.nav-link').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.nav-link')[num-1].classList.add('active');

  document.getElementById('selectorClave').value = getP().clave;

  renderT1();
  cargarHistorial();
}

function cambiarClave(clave){
  const p = getP();
  p.clave = clave;
  cargarHistorial();
}

function agregarFila(){
  const p = getP();
  p.tabla1.push({id:p.tabla1.length+1,val1:0,val2:0});
  renderT1();
}

async function editarRollo(id, rollo){
  const p = getP();
  const fila = p.tabla1.find(f=>f.id===id);
  if(!fila) return;

  const res = await fetch('php/getRollo.php',{
    method:'POST',
    body:new URLSearchParams({rollo})
  });

  const data = await res.json();

  fila.rollo = rollo;
  fila.val1 = data.valor || 0;

  renderT1();
}

function editar(id, campo, valor){
  const p = getP();
  const fila = p.tabla1.find(f=>f.id===id);
  if(fila) fila[campo]=Number(valor);
  renderT1();
}

async function procesar(){
  const p = getP();

  let total1=0,total2=0;
  p.tabla1.forEach(r=>{ total1+=r.val1; total2+=r.val2; });

  await fetch('php/procesar.php',{
    method:'POST',
    body:new URLSearchParams({
      clave:p.clave,
      v1:total1,
      v2:total2
    })
  });

  p.tabla1 = [{id:1,val1:0,val2:0}];

  renderT1();
  cargarHistorial();
}

function renderT1(){
  const p = getP();
  const tbody = document.querySelector('#tabla1 tbody');
  tbody.innerHTML='';

  let t1=0,t2=0;

  p.tabla1.forEach(r=>{
    t1+=r.val1;
    t2+=r.val2;

    const tr=document.createElement('tr');
    tr.innerHTML=`
      <td>${r.id}</td>
      <td><input class="form-control" type="number" onchange="editarRollo(${r.id},this.value)"></td>
      <td>${r.val1}</td>
      <td><input class="form-control" type="number" value="${r.val2}" onchange="editar(${r.id},'val2',this.value)"></td>
    `;
    tbody.appendChild(tr);
  });

  const tr=document.createElement('tr');
  tr.classList.add('table-secondary');
  tr.innerHTML=`<td>TOTAL</td><td></td><td>${t1}</td><td>${t2}</td>`;
  tbody.appendChild(tr);
}

async function cargarHistorial(){
  const p = getP();

  const res = await fetch('php/getHistorial.php?clave='+p.clave);
  const data = await res.json();

  const t2 = document.querySelector('#tabla2 tbody');
  const t3 = document.querySelector('#tabla3 tbody');

  t2.innerHTML='';
  t3.innerHTML='';

  data.tabla2.forEach(r=>{
    t2.innerHTML += `<tr><td>${r.id}</td><td>${r.idt1}</td><td>${r.v1}</td><td>${r.v2}</td><td>${r.v3}</td></tr>`;
  });

  data.tabla3.forEach(r=>{
    t3.innerHTML += `<tr><td>${r.id}</td><td>${r.idt1}</td><td>${r.v1}</td><td>${r.v2}</td><td>${r.v3}</td></tr>`;
  });
}

// init
cambiarPresentacion(1);
</script>

<!-- ================== SQL MYSQL ================== -->
<!--
CREATE DATABASE presentaciones_db;
USE presentaciones_db;

-- Tabla1 (Encabezado)
CREATE TABLE tabla1 (
  idt1 INT AUTO_INCREMENT PRIMARY KEY,
  clave VARCHAR(10) NOT NULL,
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Tabla2 (Acumulado)
CREATE TABLE tabla2 (
  id INT AUTO_INCREMENT PRIMARY KEY,
  idt1 INT,
  clave VARCHAR(10),
  v1 DECIMAL(10,2),
  v2 DECIMAL(10,2),
  FOREIGN KEY (idt1) REFERENCES tabla1(idt1)
);

-- Tabla3 (Histórico)
CREATE TABLE tabla3 (
  id INT AUTO_INCREMENT PRIMARY KEY,
  idt1 INT,
  clave VARCHAR(10),
  v1 DECIMAL(10,2),
  v2 DECIMAL(10,2),
  v3 DECIMAL(10,2),
  FOREIGN KEY (idt1) REFERENCES tabla1(idt1)
);

-- Catálogo de Rollos
CREATE TABLE catalogo_rollos (
  rollo INT PRIMARY KEY,
  valor DECIMAL(10,2)
);

