getCellValueBobinas(cell) {
    const row = cell.closest('tr');
    const rolloId = row.getAttribute('data-id');
    const cells = row.querySelectorAll("td");
    const cellIndex = Array.from(row.children).indexOf(cell);
    let NoBajada = cellIndex === 0 ? cell.innerText.trim() : cells[0].innerText.trim();
    let bobinas = cellIndex === 1 ? cell.innerText.trim() : cells[1].innerText.trim();
    
    // Recalcular valores de bajada LOCALMENTE
    this.recalcularValoresBajada(row);
    
    // Solo guardar, NO recargar toda la tabla
    this.saveBajadasBobinas(
        rolloId, 
        NoBajada, 
        bobinas, 
        cells[2].innerText.trim(), 
        cells[3].innerText.trim(), 
        cells[4].innerText.trim(), 
        cells[6].innerText.trim()
    );
}

// Recalcular acumulados de KG y ML en la tabla de rollos
recalcularAcumuladosRollos(tbody) {
    if (!tbody) return;
    
    let acckg = 0;
    let accml = 0;
    const filas = tbody.querySelectorAll('tr:not(.total-row):not(.btn-agregar-row)');
    
    filas.forEach(fila => {
        const kg = parseFloat(fila.cells[1]?.innerText) || 0;
        const ml = parseFloat(fila.cells[3]?.innerText) || 0;
        acckg += kg;
        accml += ml;
        
        // Actualizar celdas ocultas de acumulado
        if (fila.cells[2]) fila.cells[2].innerText = acckg;
        if (fila.cells[4]) fila.cells[4].innerText = accml;
    });
    
    // Actualizar fila de total
    const totalRow = tbody.querySelector('.total-row');
    if (totalRow) {
        if (totalRow.cells[1]) totalRow.cells[1].innerText = acckg.toFixed(3);
        if (totalRow.cells[2]) totalRow.cells[2].innerText = accml.toFixed(3);
    }
    
    return { acckg, accml };
}

// Recalcular valores de la bajada (ptcb, mlBajada, mm2Bajada, kgmb)
recalcularValoresBajada(row) {
    const bobinas = parseFloat(row.cells[1]?.innerText) || 0;
    const ancho = parseFloat(row.cells[5]?.innerText) || 0;
    const pesoBase = parseFloat(row.cells[7]?.innerText) || 0;
    
    // Obtener ML total de la tabla de rollos (esto es más complejo)
    // Por ahora, actualizar según la lógica que necesites
    
    // Ejemplo simple:
    const mlBajada = parseFloat(row.cells[3]?.innerText) || 0;
    const mm2Bajada = (mlBajada * ancho) / 1000000;
    const ptcb = mm2Bajada * pesoBase;
    const kgmb = (parseFloat(row.cells[4]?.innerText) || 0) - ptcb;
    
    if (row.cells[2]) row.cells[2].innerText = ptcb.toFixed(3);
    if (row.cells[4]) row.cells[4].innerText = mm2Bajada.toFixed(3);
    if (row.cells[6]) row.cells[6].innerText = kgmb.toFixed(3);
    
    return { ptcb, mlBajada, mm2Bajada, kgmb };
}


