function savePresentacionSpooler(){
    $Conecta = new ClassConexion();
    $conn = $Conecta->conexion("TLX004MXDB");
    $folio = $_POST["folio"];
    $presentacion = $_POST["presentacion"];
    $notbl = $_POST["notbl"];
    
    $query = "INSERT INTO tblMXPRProduccionTNTEnc (folio,Clave, NoTabla) VALUES (?,?,?)";
    $result = sqlsrv_query($conn, $query, array($folio, $presentacion, $notbl));
    
    if ($result === false) {
        $errors = sqlsrv_errors();
        $errorMsg = $errors ? $errors[0]['message'] : 'Error desconocido';
        echo json_encode(['success' => false, 'error' => $errorMsg]);
        http_response_code(500);
        return;
    }
    
    // Obtener el ID insertado correctamente
    $sql = "SELECT SCOPE_IDENTITY() AS last_id";
    $stmt = sqlsrv_query($conn, $sql);
    if (!$stmt) {
        echo json_encode(['success' => false, 'error' => 'No se pudo obtener el ID del registro']);
        http_response_code(500);
        return;
    }
    
    $row = sqlsrv_fetch_array($stmt, SQLSRV_FETCH_ASSOC);
    $last_id = $row['last_id'];
    
    // Insertar en las tablas secundarias
    $insertSuccess = $this->InsertarDataSpooler($conn, $last_id);
    
    if ($insertSuccess === true) {
        echo json_encode(['success' => true, 'idPresentacion' => $last_id]);
        http_response_code(200);
    } else {
        // Si falló la inserción en las tablas secundarias, eliminar el registro principal
        $deleteQuery = "DELETE FROM tblMXPRProduccionTNTEnc WHERE id = ?";
        $deleteStmt = sqlsrv_query($conn, $deleteQuery, array($last_id));
        
        echo json_encode(['success' => false, 'error' => $insertSuccess]);
        http_response_code(500);
    }
}

function InsertarDataSpooler($conn, $idpresentacionenc)
{
    // Iniciar transacción
    if (!sqlsrv_begin_transaction($conn)) {
        return "No se pudo iniciar la transacción";
    }
    
    try {
        // Insert tabla 1 - Valores por defecto
        $query1 = "INSERT INTO tblMXPRProduccionTNTSpoolerUno(idPt, NoRollo, KGTotalRollo, AccKG, MetrosLineales, AccML) 
                   VALUES (?, 0, 0, 0, 0, 0)";
        $params1 = array($idpresentacionenc);
        $stmt1 = sqlsrv_query($conn, $query1, $params1);
        
        if ($stmt1 === false) {
            $errors = sqlsrv_errors();
            throw new Exception("Error al insertar en SpoolerUno: " . ($errors ? $errors[0]['message'] : 'Error desconocido'));
        }
        
        // Insert tabla 2 - Valores por defecto
        $query2 = "INSERT INTO tblMXPRProduccionTNTSpoolerDos(idPT, NoBajada, bobinas, KgTotalesBajada, MLBajada, MMCBajada, KgMBajada, Comentarios) 
                   VALUES (?, 0, 0, 0, 0, 0, 0, '')";
        $params2 = array($idpresentacionenc);
        $stmt2 = sqlsrv_query($conn, $query2, $params2);
        
        if ($stmt2 === false) {
            $errors = sqlsrv_errors();
            throw new Exception("Error al insertar en SpoolerDos: " . ($errors ? $errors[0]['message'] : 'Error desconocido'));
        }
        
        // Si todo salió bien, confirmar la transacción
        if (sqlsrv_commit($conn)) {
            return true;
        } else {
            throw new Exception("No se pudo confirmar la transacción");
        }
        
    } catch (Exception $e) {
        // Si algo salió mal, deshacer la transacción
        sqlsrv_rollback($conn);
        return $e->getMessage();
    }
}

