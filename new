agregarBajadaRollo(idBitacora, clave, notbl, domtbl) {
    Swal.fire({
        title: "Rollo Maestro",
        text: "¿Deseas agregar una nueva bajada?",
        icon: "question",
        showCancelButton: true,
        confirmButtonText: "Sí, agregar",
        cancelButtonText: "Cancelar",
        confirmButtonColor: "#28a745",
        cancelButtonColor: "#d33",
    }).then(async (result) => {
        if (result.isConfirmed) {
            // Limpiar la tabla domtbl inmediatamente
            const tablaElement = document.getElementById(domtbl);
            if (tablaElement) {
                tablaElement.innerHTML = '<tr><td colspan="4" class="text-center">Cargando...</td></tr>';
            }
            
            // Guardar el nuevo registro y obtener su ID
            const nuevoId = await this.savePresentacionSpooler(idBitacora, clave, notbl);
            
            if (nuevoId) {
                // Recargar SOLO esta tabla específica con los nuevos datos
                const folio = document.getElementById("folio")?.value;
                const domtbl2 = `tblClaveSubSpooler${notbl}`;
                await this.tblPresentacionSubSpooler(folio, notbl, domtbl, domtbl2);
            }
        }
    });
}


async recargarTablaEspecifica(folio, notbl) {
    const domtbl = `tblpresentacionsub${notbl}Spooler`;
    const domtbl2 = `tblClaveSubSpooler${notbl}`;
    
    if (document.getElementById(domtbl)) {
        await this.tblPresentacionSubSpooler(folio, notbl, domtbl, domtbl2);
    }
}



function savePresentacionSpooler(){
    $Conecta = new ClassConexion();
    $conn = $Conecta->conexion("TLX004MXDB");
    $folio = $_POST["folio"];
    $presentacion = $_POST["presentacion"];
    $notbl = $_POST["notbl"];
    $array = array();
    
    $query = "INSERT INTO tblMXPRProduccionTNTEnc (folio,Clave, NoTabla) VALUES (?,?,?)";
    $result = sqlsrv_query($conn, $query, array($folio, $presentacion, $notbl));
    
    if ($result === false) {
        if (($errors = sqlsrv_errors()) != null) {
            foreach ($errors as $error) {
                echo "SQLSTATE: " . $error['SQLSTATE'] . "<br />";
                echo "code: " . $error['code'] . "<br />";
                echo "message: " . $error['message'] . "<br />";
            }
        }
        echo json_encode(['success' => false]);
        http_response_code(500);
    } else {
        $sql = "SELECT SCOPE_IDENTITY() AS last_id";
        $stmt = sqlsrv_query($conn, $sql);
        $row = sqlsrv_fetch_array($stmt, SQLSRV_FETCH_ASSOC);
        $last_id = $row['last_id'];

        $insertSuccess = $this->InsertarDataSpooler($last_id);
        
        if ($insertSuccess) {
            echo json_encode(['success' => true, 'idPresentacion' => $last_id]);
            http_response_code(200);
        } else {
            echo json_encode(['success' => false]);
            http_response_code(500);
        }
    }
}

function InsertarDataSpooler($idpresentacionenc)
{
    $Conecta = new ClassConexion();
    $conn = $Conecta->conexion("TLX004MXDB");
    
    // Iniciar transacción
    sqlsrv_begin_transaction($conn);

    // Insert tabla 1 - Usar valores por defecto
    $query1 = "INSERT INTO tblMXPRProduccionTNTSpoolerUno(idPt,NoRollo,KGTotalRollo,AccKG,MetrosLineales,AccML) 
                VALUES (?, 0, 0, 0, 0, 0)";
    $params1 = array($idpresentacionenc);
    $stmt1 = sqlsrv_query($conn, $query1, $params1);

    // Insert tabla 2 - Usar valores por defecto
    $query2 = "INSERT INTO tblMXPRProduccionTNTSpoolerDos(idPT,NoBajada,bobinas,KgTotalesBajada,MLBajada,MMCBajada,KgMBajada,Comentarios) 
                VALUES (?, 0, 0, 0, 0, 0, 0, '')";
    $params2 = array($idpresentacionenc);
    $stmt2 = sqlsrv_query($conn, $query2, $params2);

    // Validar ambas inserciones
    if($stmt1 && $stmt2){
        sqlsrv_commit($conn);
        return true;
    } else {
        sqlsrv_rollback($conn);
        return false;
    }
}
