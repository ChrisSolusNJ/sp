function savePresentacionSpooler(){
    $Conecta = new ClassConexion();
    $conn = $Conecta->conexion("TLX004MXDB");
    $folio = $_POST["folio"];
    $presentacion = $_POST["presentacion"];
    $notbl = $_POST["notbl"];
    
    $query = "INSERT INTO tblMXPRProduccionTNTEnc (folio,Clave, NoTabla) VALUES (?,?,?)";
    $result = sqlsrv_query($conn, $query, array($folio, $presentacion, $notbl));
    
    if ($result === false) {
        http_response_code(500);
        echo json_encode(['status' => 500, 'error' => 'Error al insertar']);
    } else {
        $sql = "SELECT @@IDENTITY AS last_id";
        $stmt = sqlsrv_query($conn, $sql);
        $row = sqlsrv_fetch_array($stmt, SQLSRV_FETCH_ASSOC);
        $last_id = $row['last_id'];
        
        $insertOk = $this->InsertarDataSpooler($last_id);
        
        if ($insertOk) {
            echo json_encode(['status' => 200, 'id' => $last_id]);
        } else {
            echo json_encode(['status' => 500, 'error' => 'Error en datos secundarios']);
        }
    }
}


function getDataById() {
    $Conecta = new ClassConexion();
    $conn = $Conecta->conexion("TLX004MXDB");
    $idPresentacionEnc = $_POST["idPresentacionEnc"];
    
    $query = "SELECT * FROM tblMXPRProduccionTNTSpoolerUno WHERE idPt = ?";
    $stmt = sqlsrv_query($conn, $query, array($idPresentacionEnc));
    
    $rollos = [];
    $acckg = 0;
    $accml = 0;
    
    while ($row = sqlsrv_fetch_array($stmt, SQLSRV_FETCH_ASSOC)) {
        $rollos[] = $row;
        $acckg += $row['KGTotalRollo'];
        $accml += $row['MetrosLineales'];
    }
    
    echo json_encode([
        'rollos' => $rollos,
        'acckg' => $acckg,
        'accml' => $accml
    ]);
}
